# =============================================================
# Copy this file to .env and fill in the values on your VPS.
# Never commit the real .env to git.
# =============================================================

# --- Client bundle (baked into the JS at build time) ---
# These MUST be passed as build-args to Docker (see Dockerfile ARGs).
VITE_SUPABASE_URL=https://loginapi.fotonardo.com.br
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-self-hosted-supabase
VITE_SUPABASE_PROJECT_ID=self-hosted

# --- Server runtime ---
SUPABASE_URL=https://loginapi.fotonardo.com.br
SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-self-hosted-supabase
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-self-hosted-supabase

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Runtime ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
